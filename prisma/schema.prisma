// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

enum MemberType {
  VISITOR
  REGULAR_ATTENDEE
  MEMBER
}

enum ActualChurch {
  NONE
  EVANGELICAL
  CATHOLIC
  OTHER
  NO_REPORT
}

enum HowKnow {
  FRIEND_OR_FAMILY_REFERRAL
  SOCIAL_MEDIA
  WALK_IN
  EVENT
  GOOGLE_SEARCH
  OTHER
}

enum RelationshipType {
  SPOUSE
  CHILD
  FATHER
  MOTHER
  SIBLING
  GRANDPARENT
  GRANDCHILD
  UNCLE_AUNT
  COUSIN
  OTHER
}

model User {
  id                 String       @id @default(cuid())
  nome               String
  sobrenomeEncrypted String
  email              String       @unique
  passwordHash       String
  role               Role         @default(STAFF)
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  invitesCreated       UserInvite[] @relation("InviteCreatedBy")
  inviteUsed           UserInvite?  @relation("InviteUsedBy")
  permissions          UserPermission[]
  sentMessageLogs      MemberMessageLog[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model UserInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  role        Role
  createdById String?
  usedAt      DateTime?
  usedById    String?   @unique
  createdAt   DateTime  @default(now())

  createdBy User? @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  usedBy    User? @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)

  @@map("user_invites")
}

model UserPermission {
  userId     String
  permission String
  grantedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permission])
  @@map("user_permissions")
}

model Member {
  id                 String               @id @default(cuid())
  name               String
  birthDate          DateTime
  document           String?              @unique
  phone              String?
  type               MemberType           @default(VISITOR)
  baptized           Boolean
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  visitorProfile     MemberVisitor?
  memberPrays        MemberPray[]
  principalRelations MemberRelationship[] @relation("PrincipalMember")
  relatedRelations   MemberRelationship[] @relation("RelatedMember")
  messageLogs        MemberMessageLog[]

  @@unique([name, birthDate])
  @@map("members")
}

model MemberVisitor {
  id                 String       @id @default(cuid())
  memberId           String       @unique
  actualChurch       ActualChurch
  howKnow            HowKnow
  howKnowOtherAnswer String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  member             Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("member_visitors")
}

model Pray {
  id          String       @id @default(cuid())
  text        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberPrays MemberPray[]

  @@map("prays")
}

model MemberPray {
  memberId  String
  prayId    String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  pray      Pray     @relation(fields: [prayId], references: [id], onDelete: Cascade)

  @@id([memberId, prayId])
  @@map("member_prays")
}

model MemberRelationship {
  id                String           @id @default(cuid())
  principalMemberId String
  relatedMemberId   String
  relationshipType  RelationshipType
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  principalMember   Member           @relation("PrincipalMember", fields: [principalMemberId], references: [id], onDelete: Cascade)
  relatedMember     Member           @relation("RelatedMember", fields: [relatedMemberId], references: [id], onDelete: Cascade)

  @@unique([principalMemberId, relatedMemberId, relationshipType])
  @@map("member_relationships")
}

model MessageTemplate {
  id        String    @id @default(cuid())
  title     String
  body      String
  order     Int
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sentLogs  MemberMessageLog[]

  @@map("message_templates")
}

model MemberMessageLog {
  id                String           @id @default(cuid())
  memberId          String
  member            Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  messageTemplateId String?
  messageTemplate   MessageTemplate? @relation(fields: [messageTemplateId], references: [id], onDelete: SetNull)
  messageTitle      String
  messageBody       String
  sentAt            DateTime         @default(now())
  sentByUserId      String?
  sentByUser        User?            @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@map("member_message_logs")
}
